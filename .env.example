# Faxio IT — Environment Variables
# Copy this file to .env.local and fill in values

# Site URL (used for absolute URLs and OG metadata)
NEXT_PUBLIC_SITE_URL=https://faxioit.com

# Contact form email handler (e.g. Resend, SendGrid, Formspree)
# If using Resend:
# RESEND_API_KEY=your_resend_api_key

# If using SendGrid:
# SENDGRID_API_KEY=your_sendgrid_api_key

# If using Formspree (no backend needed — set the form action URL):
# NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager (optional)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
